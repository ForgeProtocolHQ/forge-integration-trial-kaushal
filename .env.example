# =============================================================================
# Forge Integration Trial — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` (root, for the SDK/tests) and `apps/demo/.env.local` (for the
# Next.js demo). NEVER put real secrets, private keys, or production endpoints
# in this repository. All values below are PLACEHOLDERS.
# =============================================================================

# --- Chain --------------------------------------------------------------------
# BNB Smart Chain Testnet. Chain id 97 is public and fixed.
FORGE_CHAIN_ID=97

# Public BNB testnet RPC. Replace with any public testnet endpoint you trust.
# Do NOT commit private/keyed RPC URLs.
FORGE_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
FORGE_EXPLORER_URL=https://testnet.bscscan.com

# --- Contract addresses (PLACEHOLDERS — supply real BNB testnet addresses) ----
# Leave as the zero address to run in "no addresses configured" mode; the SDK
# and demo will surface a clear "not configured" state instead of fabricating
# data. Replace with deployed BNB testnet addresses to exercise live reads.
FORGE_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
FORGE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

# Block from which historical pool discovery should begin scanning.
FORGE_FACTORY_DEPLOY_BLOCK=0

# --- Next.js demo (client-exposed; must be NEXT_PUBLIC_*) ----------------------
# These mirror the values above for the browser bundle.
NEXT_PUBLIC_FORGE_CHAIN_ID=97
NEXT_PUBLIC_FORGE_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
NEXT_PUBLIC_FORGE_EXPLORER_URL=https://testnet.bscscan.com
NEXT_PUBLIC_FORGE_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FORGE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FORGE_FACTORY_DEPLOY_BLOCK=0

# Optional WalletConnect project id for the demo (public id, not a secret).
# Leave blank to use injected/browser wallets only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
