{
  "name": "@forge-trial/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Typed SDK wrappers for Forge Protocol on BNB testnet (evaluation/trial).",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
